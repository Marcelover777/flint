{
  "name": "flint-installer",
  "version": "0.1.0",
  "description": "Flint installer \u2014 detects your AI coding agents and installs flint for each one.",
  "license": "MIT",
  "author": "Marcelover777",
  "homepage": "https://github.com/Marcelover777/flint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcelover777/flint.git"
  },
  "bugs": {
    "url": "https://github.com/Marcelover777/flint/issues"
  },
  "bin": {
    "flint": "./bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test tests/installer/*.test.mjs",
    "test:optimizer": "node --test tests/core/*.test.mjs tests/hooks/*.test.mjs tests/mcp/*.test.mjs tests/commands/*.test.mjs",
    "test:all": "node --test tests/installer/*.test.mjs tests/core/*.test.mjs tests/hooks/*.test.mjs tests/mcp/*.test.mjs tests/commands/*.test.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "plugins/",
    "commands/",
    "dist/flint.skill",
    "README.md",
    "LICENSE"
  ],
  "contributors": [
    "Julius Brussee (caveman upstream, MIT)"
  ]
}
